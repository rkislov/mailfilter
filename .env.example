POSTGRES_DB=anispam
POSTGRES_USER=anispam
POSTGRES_PASSWORD=anispam
DATABASE_URL=postgresql+psycopg2://anispam:anispam@postgres:5432/anispam
REDIS_URL=redis://redis:6379/0
POLICY_API_URL=http://policy-api:8080
MILTER_POLICY_URL=http://policy-api:8080/api/v1/milter/evaluate
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
WEB_UI_API_BASE=http://localhost:8080/api/v1
DEFAULT_SUPERADMIN_EMAIL=admin@local.anispam
DEFAULT_SUPERADMIN_PASSWORD=change-me
JWT_SECRET=change-me
AI_PROVIDER_MODE=disabled
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_MODEL=llama3.1
GPUSTACK_BASE_URL=http://gpustack:8080/v1
GPUSTACK_API_KEY=
GPUSTACK_MODEL=llama3.1
MILTER_SOCKET=inet:9900@0.0.0.0
MILTER_TIMEOUT_SECONDS=30
SMTP_DECISION_TIMEOUT_MS=1500
ENABLE_AI_ENFORCEMENT=false
SCAN_QUEUE_NAME=anispam:scan-jobs
CLAMAV_CONFIG_DIR=/shared/clamav-config
